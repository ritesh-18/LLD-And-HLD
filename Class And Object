// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;


class Student{
    public:
    int age ;
    int rollno;
    string name;
    Student(int rollno  , int age , string name){
        this->name =name;
        this->age=age;
        this->rollno=rollno;
        
    }
    void study(){
        cout<<" student "<<this->name << " is studying"<<endl;
    }
    
};

int main() {
    Student *s1=new Student(20 ,17 , "ritesh"); // dynamic memory allocation
    Student s2(2 , 18 , "ram"); //static memory(stack)
    s2.study();
    s1->study();

    return 0;
}
